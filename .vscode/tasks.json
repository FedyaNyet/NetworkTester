{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "netmon: Smoke run (10s)",
			"type": "shell",
			"command": "uv",
			"args": [
				"run", "-m", "netmon.monitor",
				"--duration", "10",
				"--interval", "0.5",
				"--count", "2",
				"--timeout-ms", "200"
			],
			"group": "test",
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "netmon: 1h run",
			"type": "shell",
			"command": "uv",
			"args": [
				"run", "-m", "netmon.monitor",
				"--duration", "3600"
			],
			"group": "test",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "netmon: Analyze latest",
			"type": "shell",
			"command": "uv",
			"args": [
				"run", "-m", "netmon.analyze"
			],
			"group": "test",
			"isBackground": false,
			"problemMatcher": []
		}
	]
}
